PORT=3300
# 监听所有网络接口，Android 设备/模拟器才能访问
# Android 模拟器通过 10.0.2.2:3300 连接宿主机
# 真机通过宿主机局域网 IP 连接，如 192.168.x.x:3300
HOST=0.0.0.0
NODE_ENV=development
DATABASE_URL="file:./dev.db"
JWT_SECRET="replace-with-at-least-32-chars-local-secret"
# Web 前端 CORS 白名单（Android 原生客户端无需配置此项）
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000"
